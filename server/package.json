{
  "name": "@simple-asteroid-game/server",
  "version": "1.0.0",
  "private": true,
  "description": "This is the server for the asteroid game",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"node --import tsx ./src/server.ts\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "author": "Rico Trebeljahr",
  "license": "ISC",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@trpc/server": "^11.15.0",
    "cors": "^2.8.5",
    "express": "^4.17.1",
    "ioredis": "^5.10.1",
    "socket.io": "^4.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.8",
    "@types/express": "^4.17.8",
    "@types/node": "^13.13.30",
    "nodemon": "^3.1.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
